{
    "name": "@bobosneefdev/zongodb",
    "version": "3.0.4",
    "description": "Zod schemas + MongoDB",
    "packageManager": "bun@1.3.8",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "directories": {
        "test": "test"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org"
    },
    "scripts": {
        "lint": "biome check --fix",
        "format": "biome format --write .",
        "check": "tsc --noEmit",
        "check:full": "bun run lint && bun run format && bun run check",
        "build": "tsdown",
        "build:full": "bun run check:full && bun run build",
        "test": "bun test",
        "prepublishOnly": "bun run build:full && bun run test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bobosneefdev/ZongoDB.git"
    },
    "keywords": [
        "mongodb",
        "zod"
    ],
    "author": "bobosneefdev",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/bobosneefdev/ZongoDB/issues"
    },
    "homepage": "https://github.com/bobosneefdev/ZongoDB#readme",
    "devDependencies": {
        "@biomejs/biome": "^2.4.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.1.0",
        "tsdown": "^0.21.0-beta.2",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "zod": "^4.3.6",
        "mongodb": "^7.0.0"
    },
    "dependencies": {
        "dotenv": "^17.2.3"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ]
}
